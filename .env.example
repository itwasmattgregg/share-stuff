DATABASE_URL="file:./dev.db"
SESSION_SECRET="super-duper-s3cret"

# Email (password reset + signup verification)
# Without email configured, links are logged to the server console in development.
#
# Recommended: Resend (https://resend.com) — free tier is 3,000 emails/month.
# 1. Create an API key at https://resend.com/api-keys
# 2. Verify your sending domain at https://resend.com/domains
# 3. Set RESEND_API_KEY and EMAIL_FROM below
RESEND_API_KEY=""
EMAIL_FROM="ShareStuff <noreply@yourdomain.com>"

# Optional explicit SMTP settings (override Resend defaults if needed)
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="resend"
# SMTP_PASS="re_your_api_key"

# Optional Cloudflare R2 settings for item photo uploads.
# Without these, items work normally but photo uploads are disabled.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
