datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  role  String  @default("USER")
  emailVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  password Password?
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  // Community relationships
  ownedCommunities     Community[]           @relation("CommunityOwner")
  communityMemberships CommunityMembership[]
  items                Item[]
  lendingRequests      LendingRequest[]      @relation("Requester")
  receivedRequests     LendingRequest[]      @relation("ItemOwner")
  reports              Report[]
  notifications        Notification[]
  communityInvites      CommunityInvite[]
}

model Password {
  hash String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String @unique
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Community {
  id          String  @id @default(cuid())
  name        String
  description String?
  rules       String?
  isListed    Boolean @default(true)
  isArchived  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  ownerId String
  owner   User   @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  memberships CommunityMembership[]
  invites       CommunityInvite[]
}

model CommunityInvite {
  id          String   @id @default(cuid())
  token       String   @unique
  expiresAt   DateTime

  createdAt DateTime @default(now())

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([expiresAt])
}

model CommunityMembership {
  id     String @id @default(cuid())
  status String @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

model Item {
  id          String  @id @default(cuid())
  name        String
  description String?
  category    String? // e.g., "book", "tool", "dvd", "game"
  condition   String? // e.g., "excellent", "good", "fair"
  photoKey    String?
  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  lendingRequests LendingRequest[]
  itemTags        ItemTag[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  itemTags  ItemTag[]
  createdAt DateTime  @default(now())
}

model ItemTag {
  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@index([tagId])
}

model LendingRequest {
  id           String  @id @default(cuid())
  status       String  @default("PENDING")
  requestNote  String?
  responseNote String?
  borrowedAt   DateTime?
  returnedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  requesterId String
  requester   User   @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)

  itemOwnerId String
  itemOwner   User   @relation("ItemOwner", fields: [itemOwnerId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // Removed unique constraint to allow multiple requests per item
}

model Report {
  id          String  @id @default(cuid())
  reportType  String
  targetId    String // ID of the user or community being reported
  reason      String
  description String
  evidence    String?
  status      String  @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // "COMMUNITY_APPROVED", "COMMUNITY_REJECTED", "LENDING_REQUEST", "LENDING_APPROVED", etc.
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?  // Optional link to relevant page

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
